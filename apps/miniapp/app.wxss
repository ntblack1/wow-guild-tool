page {
  min-height: 100%;
  background:
    radial-gradient(circle at 50% 0%, rgba(127, 87, 35, 0.34), transparent 420rpx),
    linear-gradient(180deg, #17120d 0%, #0d0b09 58%, #080706 100%);
  color: #f8e8c0;
  font-size: 28rpx;
  line-height: 1.55;
}

.page {
  min-height: 100vh;
  padding: 24rpx;
  box-sizing: border-box;
}

.section {
  margin-bottom: 28rpx;
}

.card,
.panel {
  position: relative;
  padding: 24rpx;
  margin-bottom: 22rpx;
  overflow: hidden;
  background:
    linear-gradient(180deg, rgba(50, 39, 27, 0.96), rgba(26, 21, 16, 0.98)),
    #241b13;
  border: 2rpx solid rgba(210, 166, 83, 0.58);
  border-radius: 12rpx;
  box-shadow: 0 14rpx 34rpx rgba(0, 0, 0, 0.34), inset 0 0 0 1rpx rgba(255, 236, 177, 0.08);
  box-sizing: border-box;
}

.card::before,
.panel::before {
  position: absolute;
  top: 0;
  right: 0;
  left: 0;
  height: 2rpx;
  background: linear-gradient(90deg, transparent, rgba(255, 223, 142, 0.7), transparent);
  content: "";
}

.title {
  color: #ffe3a0;
  font-size: 34rpx;
  font-weight: 700;
  letter-spacing: 0;
}

.subtitle {
  color: #c9b07b;
  font-size: 24rpx;
}

.muted {
  color: #b8a783;
}

.row {
  display: flex;
  align-items: center;
  justify-content: space-between;
  gap: 16rpx;
}

.button-row {
  display: flex;
  gap: 16rpx;
  flex-wrap: wrap;
}

button {
  margin: 0;
  border-radius: 8rpx;
}

button::after {
  border: 0;
}

.primary-button {
  color: #fff4cf;
  background: linear-gradient(180deg, #4e7d2d, #285319);
  border: 2rpx solid rgba(225, 196, 107, 0.82);
  box-shadow: inset 0 1rpx 0 rgba(255, 255, 255, 0.2), 0 8rpx 18rpx rgba(20, 42, 13, 0.32);
}

.secondary-button {
  color: #f7d88b;
  background: linear-gradient(180deg, #3a2d20, #201811);
  border: 2rpx solid rgba(199, 150, 67, 0.72);
}

.danger-button {
  color: #fff1dc;
  background: linear-gradient(180deg, #8c3e24, #5d2016);
  border: 2rpx solid rgba(219, 139, 72, 0.7);
}

.input,
.textarea,
.picker {
  min-height: 78rpx;
  padding: 0 22rpx;
  color: #f7e5ba;
  background: rgba(13, 10, 8, 0.78);
  border: 2rpx solid rgba(166, 124, 57, 0.72);
  border-radius: 8rpx;
  box-sizing: border-box;
}

.textarea {
  min-height: 168rpx;
  padding-top: 18rpx;
}

.field {
  margin-bottom: 22rpx;
}

.label {
  margin-bottom: 10rpx;
  color: #e5c57d;
  font-size: 25rpx;
  font-weight: 600;
}

.empty {
  padding: 44rpx 20rpx;
  color: #b8a783;
  text-align: center;
}

.hero-card {
  position: relative;
  min-height: 290rpx;
  padding: 28rpx;
  overflow: hidden;
  border-radius: 14rpx;
  border: 2rpx solid rgba(232, 186, 86, 0.68);
  box-shadow: 0 18rpx 42rpx rgba(0, 0, 0, 0.42);
}

.hero-card image {
  position: absolute;
  top: 0;
  right: 0;
  bottom: 0;
  left: 0;
  width: 100%;
  height: 100%;
}

.hero-overlay {
  position: absolute;
  top: 0;
  right: 0;
  bottom: 0;
  left: 0;
  background: linear-gradient(90deg, rgba(11, 8, 6, 0.88), rgba(11, 8, 6, 0.42) 56%, rgba(11, 8, 6, 0.72));
}

.hero-content {
  position: relative;
  z-index: 1;
}

.eyebrow {
  display: inline-flex;
  align-items: center;
  min-height: 34rpx;
  padding: 0 14rpx;
  color: #2a1809;
  font-size: 22rpx;
  font-weight: 700;
  background: linear-gradient(180deg, #ffdd82, #b87b2d);
  border-radius: 999rpx;
}

.status-badge,
.role-chip {
  display: inline-flex;
  align-items: center;
  justify-content: center;
  min-height: 42rpx;
  padding: 0 16rpx;
  color: #fce8b0;
  font-size: 22rpx;
  font-weight: 700;
  border-radius: 999rpx;
  border: 1rpx solid rgba(255, 224, 149, 0.45);
  white-space: nowrap;
}

.status-open {
  background: rgba(65, 125, 38, 0.9);
}

.status-locked {
  background: rgba(126, 83, 34, 0.92);
}

.status-finished {
  background: rgba(85, 83, 77, 0.92);
}

.status-draft {
  background: rgba(64, 73, 96, 0.92);
}

.role-tank {
  background: rgba(54, 105, 159, 0.88);
}

.role-healer {
  background: rgba(66, 130, 71, 0.88);
}

.role-melee {
  background: rgba(158, 75, 50, 0.9);
}

.role-ranged {
  background: rgba(115, 75, 160, 0.9);
}

.progress {
  height: 14rpx;
  overflow: hidden;
  background: rgba(11, 8, 6, 0.86);
  border: 1rpx solid rgba(215, 166, 75, 0.45);
  border-radius: 999rpx;
}

.progress-bar {
  height: 100%;
  background: linear-gradient(90deg, #8fbf3d, #f4c762);
  border-radius: 999rpx;
}
