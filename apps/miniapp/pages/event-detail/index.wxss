.detail-hero {
  min-height: 390rpx;
  margin-bottom: 24rpx;
}

.detail-title {
  margin-top: 58rpx;
  color: #fff0bd;
  font-size: 48rpx;
  font-weight: 800;
  line-height: 1.15;
}

.detail-time {
  margin-top: 12rpx;
  color: #f1d08a;
  font-size: 26rpx;
}

.detail-progress {
  width: 62%;
  margin-top: 26rpx;
}

.detail-count {
  margin-top: 10rpx;
  color: #d7c49c;
  font-size: 24rpx;
}

.retry-button {
  margin-top: 18rpx;
}

.intel-grid {
  display: grid;
  grid-template-columns: repeat(2, minmax(0, 1fr));
  gap: 16rpx;
  margin-top: 18rpx;
}

.intel-item,
.stat-box,
.role-need {
  padding: 18rpx;
  background: rgba(12, 9, 7, 0.58);
  border: 1rpx solid rgba(199, 150, 67, 0.4);
  border-radius: 10rpx;
  box-sizing: border-box;
}

.description {
  margin-top: 20rpx;
  color: #ead6a9;
  font-size: 26rpx;
}

.role-grid {
  display: grid;
  grid-template-columns: repeat(2, minmax(0, 1fr));
  gap: 16rpx;
  margin-top: 18rpx;
}

.need-number {
  margin-top: 12rpx;
  color: #ffe3a0;
  font-size: 32rpx;
  font-weight: 800;
}

.stats-row {
  display: grid;
  grid-template-columns: repeat(4, minmax(0, 1fr));
  gap: 12rpx;
  margin-top: 18rpx;
}

.stat-box {
  text-align: center;
}

.stat-number {
  color: #ffe3a0;
  font-size: 34rpx;
  font-weight: 800;
}

.action-row {
  margin-bottom: 26rpx;
}

.action-button {
  flex: 1;
}

.signup-card {
  line-height: 1.7;
}

.signup-name {
  color: #fff0bd;
  font-size: 30rpx;
  font-weight: 700;
}

.note {
  margin-top: 10rpx;
  color: #d7c49c;
}
