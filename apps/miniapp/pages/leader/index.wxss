.leader-hero {
  background:
    linear-gradient(135deg, rgba(59, 39, 20, 0.96), rgba(18, 13, 9, 0.98)),
    #261b12;
}

.hero-title {
  margin-top: 14rpx;
  margin-bottom: 8rpx;
}

.need-input-grid {
  display: grid;
  grid-template-columns: repeat(2, minmax(0, 1fr));
  gap: 14rpx;
  margin-bottom: 22rpx;
}

.section-title-row {
  margin-bottom: 16rpx;
}

.error-card {
  color: #ffd2c2;
  background:
    linear-gradient(180deg, rgba(89, 31, 22, 0.94), rgba(36, 18, 13, 0.96)),
    #331812;
  border-color: rgba(229, 116, 83, 0.72);
}

.leader-event-card {
  line-height: 1.7;
}

.event-actions {
  margin-top: 18rpx;
}

.event-actions button {
  margin-bottom: 8rpx;
}

.summary-grid {
  display: grid;
  grid-template-columns: repeat(2, minmax(0, 1fr));
  gap: 16rpx;
  margin-top: 16rpx;
}

.summary-item {
  padding: 18rpx;
  color: #ffe3a0;
  font-size: 26rpx;
  text-align: center;
  background: rgba(12, 9, 7, 0.58);
  border: 1rpx solid rgba(199, 150, 67, 0.4);
  border-radius: 10rpx;
}

.compact-card {
  line-height: 1.75;
}
