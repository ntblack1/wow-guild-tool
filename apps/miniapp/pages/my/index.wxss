.member-hero {
  background:
    linear-gradient(135deg, rgba(48, 35, 22, 0.96), rgba(18, 13, 9, 0.98)),
    #261b12;
}

.member-title {
  margin-top: 14rpx;
  margin-bottom: 8rpx;
}

.clear-button {
  margin-top: 18rpx;
}

.picker {
  display: flex;
  align-items: center;
}

.member-card {
  line-height: 1.8;
}

.section-title-row {
  margin-bottom: 16rpx;
}

.character-card {
  display: flex;
  gap: 18rpx;
  padding: 18rpx;
  margin-bottom: 18rpx;
  background: linear-gradient(180deg, rgba(48, 37, 25, 0.96), rgba(22, 17, 13, 0.98));
  border: 2rpx solid rgba(210, 166, 83, 0.58);
  border-radius: 12rpx;
  box-shadow: 0 14rpx 32rpx rgba(0, 0, 0, 0.3);
  box-sizing: border-box;
}

.character-avatar {
  flex: none;
  width: 148rpx;
  height: 148rpx;
  border: 2rpx solid rgba(229, 190, 104, 0.68);
  border-radius: 12rpx;
  background: #15100c;
}

.character-body {
  flex: 1;
  min-width: 0;
}

.character-name {
  color: #fff0bd;
  font-size: 32rpx;
  font-weight: 800;
}

.character-meta {
  margin-top: 6rpx;
  color: #d7c49c;
  font-size: 24rpx;
}

.character-actions {
  margin-top: 14rpx;
}

.checkbox-row {
  display: flex;
  align-items: center;
  gap: 12rpx;
  margin: 20rpx 0;
  color: #e5c57d;
  font-size: 28rpx;
}

.signup-record {
  line-height: 1.75;
}
